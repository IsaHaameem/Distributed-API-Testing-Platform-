# Local development defaults only — never reuse these for a real deployment.

# --- Postgres (consumed by the postgres container's own init) ---
POSTGRES_USER=apiplatform
POSTGRES_PASSWORD=apiplatform_dev_password
POSTGRES_DB=apiplatform
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (host port mapping; the app always binds to 8000 inside its container) ---
BACKEND_PORT=8000

# --- App settings ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Connection strings the FastAPI app actually reads (built from the values above) ---
DATABASE_URL=postgresql+asyncpg://apiplatform:apiplatform_dev_password@postgres:5432/apiplatform
REDIS_URL=redis://redis:6379/0