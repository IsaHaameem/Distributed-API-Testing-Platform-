# Local development defaults only — never reuse these for a real deployment.

# --- Postgres (consumed by the postgres container's own init) ---
POSTGRES_USER=apiplatform
POSTGRES_PASSWORD=apiplatform_dev_password
POSTGRES_DB=apiplatform
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (host port mapping; the app always binds to 8000 inside its container) ---
BACKEND_PORT=8000

# --- App settings ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Connection strings the FastAPI app actually reads (built from the values above) ---
DATABASE_URL=postgresql+asyncpg://apiplatform:apiplatform_dev_password@postgres:5432/apiplatform
REDIS_URL=redis://redis:6379/0

# --- JWT ---
# Generate a real value before starting the stack: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=REPLACE_ME_WITH_A_GENERATED_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Worker ---
WORKER_CAPACITY=10
WORKER_HEARTBEAT_INTERVAL_SECONDS=5

# --- Rate limiting (Redis token bucket per target host) ---
# Disabled by default -- preserves existing behavior until explicitly opted in.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_PER_SECOND=5.0